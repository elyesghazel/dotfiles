[global]
    monitor = 0
    # behavior of notifications => show on active / focused workspace
    follow = mouse
    
    # Maße und Position
    width = 300
    height = 200
    origin = top-right
    offset = 15x15
    
    gap_size = 10
    
    corner_radius = 10
    
    ### Progress bar ###
    progress_bar = true
    progress_bar_height = 8
    progress_bar_frame_width = 1
    progress_bar_min_width = 150
    progress_bar_max_width = 300
    
    indicate_hidden = yes
    transparency = 0
    separator_height = 2
    padding = 12
    horizontal_padding = 12
    text_icon_padding = 10
    
    # Mocha Blue Frame
    frame_width = 2
    frame_color = "#89b4fa"
    separator_color = frame
    
    ### Text ###
    font = JetBrainsMono Nerd Font 10
    markup = full
    format = "<b>%s</b>\n%b"
    alignment = left
    show_age_threshold = 60
    ellipsize = middle
    
    ### Icons ###
    icon_position = left
    max_icon_size = 48
    
    # path to icons, separated by colon. Dunst will look for icons in these directories in order, papirus-icon-theme make sure is installed.
    icon_path = /usr/share/icons/Papirus-Dark/16x16/status/:/usr/share/icons/Papirus-Dark/16x16/devices/:/usr/share/icons/Papirus-Dark/16x16/apps/

[urgency_low]
    background = "#1e1e2e"
    foreground = "#cdd6f4"
    frame_color = "#89b4fa"
    timeout = 5

[urgency_normal]
    background = "#1e1e2e"
    foreground = "#cdd6f4"
    frame_color = "#89b4fa"
    timeout = 10

[urgency_critical]
    background = "#1e1e2e"
    foreground = "#cdd6f4"
    frame_color = "#f38ba8"
    timeout = 0
