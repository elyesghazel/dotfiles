{
    "layer": "top",
    "position": "top",
    "height": 38,
    "margin": "8 8 0 8",
    "spacing": 0,

    "group/left": {
        "orientation": "horizontal",
        "modules": ["custom/start", "hyprland/workspaces", "mpris"]
    },

    "group/right": {
        "orientation": "horizontal",
        "modules": ["cpu", "memory", "pulseaudio", "network", "bluetooth", "battery", "tray"]
    },

    "modules-left":   ["group/left"],
    "modules-center": ["clock"],
    "modules-right":  ["group/right"],

    "hyprland/workspaces": {
        "format": "{id}",
        "on-scroll-down": "hyprctl dispatch workspace e+1",
        "on-scroll-up":   "hyprctl dispatch workspace e-1",
        "persistent-workspaces": {
            "DP-2":     [1,2,3,4,5],
            "HDMI-A-2": [6,7,8,9,10]
        },
        "cursor": true
    },

    "clock": {
        "timezone": "Europe/Zurich",
        "tooltip-format": "<tt><small>{calendar}</small></tt>",
        "format":     "{:%H:%M}",
        "format-alt": "{:%A, %d %B %Y}",
        "on-click-right": "hyprctl dispatch exec 'kitty --class=peaclock -e peaclock'",
        "calendar": {
            "mode": "month",
            "weeks-pos": "right",
            "format": {
                "months":   "<span color='#c8c8c8'><b>{}</b></span>",
                "days":     "<span color='#c8c8c8'><b>{}</b></span>",
                "weeks":    "<span color='#888'><b>W{}</b></span>",
                "weekdays": "<span color='#888'><b>{}</b></span>",
                "today":    "<span color='#fff'><b><u>{}</u></b></span>"
            }
        }
    },

    "mpris": {
        "format":         "{artist} — {title}",
        "tooltip-format": "{album}",
        "format-paused":  " {artist} — {title}",
        "on-click":       "playerctl play-pause",
        "on-scroll-up":   "playerctl previous",
        "on-scroll-down": "playerctl next",
        "max-length": 38
    },

    "pulseaudio": {
        "format":           "{icon}",
        "format-bluetooth": "{icon}",
        "on-click":         "pactl set-sink-mute @DEFAULT_SINK@ toggle",
        "on-click-right":   "pavucontrol",
        "on-scroll-up":     "wpctl set-volume @DEFAULT_SINK@ 2%+",
        "on-scroll-down":   "wpctl set-volume @DEFAULT_SINK@ 2%-",
        "tooltip-format":   "{volume}%",
        "format-muted":     "󰝟",
        "scroll-step": 2,
        "format-icons": {
            "headphone":  "",
            "headset":    "",
            "default":    ["󰕿", "󰖀", "󰕾"]
        }
    },

    "network": {
        "interval": 10,
        "format-disabled":    "󰤭",
        "format-disconnected": "󰤮",
        "format-wifi":        "󰤨",
        "format-ethernet":    "󰈀",
        "tooltip-format": "{essid}  {signalStrength}%\n{bandwidthUpBytes}  {bandwidthDownBytes}",
        "on-click": "kitty gazelle",
        "menu": "on-click-right",
        "menu-file": "~/.config/waybar/context/network.xml",
        "menu-actions": {
            "action-1": "nmcli radio wifi off",
            "action-2": "nmcli radio wifi on",
            "action-3": "hyprctl dispatch exec '[float] kitty -e nmtui'",
            "action-4": "hyprctl dispatch exec nm-connection-editor"
        }
    },

    "bluetooth": {
        "format":                   "󰂲",
        "format-on":                "󰂯",
        "format-connected":         "󰂱 {device_alias}",
        "tooltip-format":           "Bluetooth off",
        "tooltip-format-on":        "Bluetooth on",
        "tooltip-format-connected": "{device_alias}",
        "tooltip-format-enumerate-connected-battery": "{device_alias}  {device_battery_percentage}%",
        "on-click":       "~/.local/bin/toggle_bluetooth &",
        "menu": "on-click-right",
        "menu-file": "~/.config/waybar/context/bluetooth.xml",
        "menu-actions": {
            "action-1": "bluetoothctl power on",
            "action-2": "bluetoothctl power off",
            "action-3": "kitty bluetui"
        }
    },

    "battery": {
        "interval": 30,
        "full-at": 100,
        "format-full":     "󰁹",
        "format":          "{icon} {capacity}%",
        "format-charging": "󰂄 {capacity}%",
        "format-icons":    ["󰁺","󰁻","󰁼","󰁽","󰁾","󰁿","󰂀","󰂂","󰁹"],
        "tooltip-format":  "{capacity}%  {timeTo}",
        "states": {
            "warning": 30,
            "critical": 15
        }
    },

    "tray": {
        "icon-size": 14,
        "spacing": 8
    },

    "cpu": {
        "interval": 5,
        "format": "󰻠 {usage}%",
        "states": { "warning": 80, "critical": 90 }
    },

    "memory": {
        "interval": 5,
        "format": "󰍛 {used:0.1f}G",
        "states": { "warning": 80, "critical": 90 }
    },

    "custom/start": {
        "format": "",
        "tooltip": false,
        "on-click": "vicinae toggle"
    }
}
